{
    "name": "frank-bokdam/magento2-product-relations",
    "description": "Magento 2 module that automatically captures behavioural product affinity data (viewed_together, searched_together, sold_together).",
    "type": "magento2-module",
    "license": "MIT",
    "authors": [
        {
            "name": "Frank Bokdam",
            "email": "frank@frankbokdam.com"
        }
    ],
    "keywords": ["magento2", "magento", "module", "product-relations", "affinity", "recommendations"],
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0",
        "magento/framework": "*"
    },
    "require-dev": {
        "magento/magento-coding-standard": "*",
        "phpstan/phpstan": "^1.0",
        "phpstan/phpstan-phpunit": "^1.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "files": ["src/registration.php"],
        "psr-4": {
            "FrankBokdam\\ProductRelations\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FrankBokdam\\ProductRelations\\Test\\": "src/Test/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "([ $COMPOSER_DEV_MODE -eq 0 ] || vendor/bin/phpcs --config-set installed_paths ../../magento/magento-coding-standard/)"
        ],
        "post-update-cmd": [
            "([ $COMPOSER_DEV_MODE -eq 0 ] || vendor/bin/phpcs --config-set installed_paths ../../magento/magento-coding-standard/)"
        ]
    }
}
